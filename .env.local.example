# Bank Fee Index v2 — local environment template
# Copy to .env.local and fill in. .env.local is gitignored.

# Postgres (Supabase). Use direct connection (port 5432) for local dev.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Supabase (optional in M1)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Hamilton, Knox)
ANTHROPIC_API_KEY=

# R2 (object storage for Atlas)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
